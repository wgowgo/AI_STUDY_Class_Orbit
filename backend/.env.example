OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# NEIS (나이스) — 키, 시도교육청코드, 학교코드가 모두 있어야 실호출, 아니면 샘플
NEIS_API_KEY=
NEIS_ATPT_OFCDC_SC_CODE=
NEIS_SD_SCHUL_CODE=
# NEIS 응답 캐시(초). 0이면 캐시 비활성
NEIS_CACHE_TTL_SECONDS=60

# KESS / 학교알리미 — 실연동 시 공공데이터포털 등 스펙에 맞춰 코드에서 교체
KESS_API_KEY=
SCHOOL_ALIMI_API_KEY=

# ── 배포 보안 (공개 인터넷에 둘 때 필수 확인) ─────────────────────────────
# APP_ENV=production 이면 아래 두 항목이 미설정일 때 서버가 기동하지 않습니다.
APP_ENV=development

# CORS — 쉼표 구분. 로컬 개발: * / 프로덕션: https://your-frontend.example
# * 는 모든 출처 허용(자격 증명 비활성). OpenAI 연동 시 공개 배포에 * 는 피하세요.
CORS_ORIGINS=*

# 채팅·STT·NLQ 등 OpenAI 비용이 나는 엔드포인트 보호용.
# 설정 시 요청 헤더 X-Internal-Key 또는 Authorization: Bearer <동일값> 필요.
# 프론트는 web/.env 에 VITE_INTERNAL_API_KEY 를 같은 값으로 맞춥니다.
INTERNAL_API_KEY=

# 분당 IP당 요청 상한(전역 /api). 0이면 비활성
RATE_LIMIT_PER_MINUTE=120
