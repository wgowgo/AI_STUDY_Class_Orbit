OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# NEIS (나이스) — 키, 시도교육청코드, 학교코드가 모두 있어야 실호출, 아니면 샘플
NEIS_API_KEY=
NEIS_ATPT_OFCDC_SC_CODE=
NEIS_SD_SCHUL_CODE=
# NEIS 응답 캐시(초). 0이면 캐시 비활성
NEIS_CACHE_TTL_SECONDS=60

# KESS / 학교알리미 — 실연동 시 공공데이터포털 등 스펙에 맞춰 코드에서 교체
KESS_API_KEY=
SCHOOL_ALIMI_API_KEY=

# CORS — 쉼표 구분. * 이면 개발 편의(자격 증명 비활성). 프로덕션은 https://your-frontend.example 형태로 나열
CORS_ORIGINS=*

# 분당 IP당 요청 상한(전역 /api). 0이면 비활성
RATE_LIMIT_PER_MINUTE=120

# 채팅, STT 등 민감 엔드포인트를 외부에 열 때: 값을 설정하면 요청에 X-Internal-Key 또는 Authorization: Bearer 동일 값 필요
INTERNAL_API_KEY=
